{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lamzu Aurora",
  "version": "0.1.0",
  "identifier": "com.example.lamzu-aurora",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lamzu Aurora Tauri",
        "width": 1240,
        "height": 900,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/udev/rules.d/99-lamzu.rules": "../packaging/99-lamzu.rules"
        }
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
